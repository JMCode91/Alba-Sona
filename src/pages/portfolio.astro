---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Portfolio | Alba Sona MAKEUP">
    
    <main class="portfolio-main">
        <section class="portfolio-highlights">
            <div class="highlights-textos">
                <h1>Algunos de mis trabajos favoritos.</h1>
            </div>
            
            <div class="collage-grid">
                <div class="collage-item item-big-v">
                    <img src="https://media.istockphoto.com/id/1431986496/es/foto/novia-emocionada-en-boda-con-ramo-en-parque-natural-con-%C3%A1rboles-verdes-bokeh-y-sol-de-verano.jpg?s=612x612&w=0&k=20&c=axV1DyL4dZEWTqaukrO8hHv_6zX4z8x_8MnfPMs0enM=" alt="Maquillaje novia principal">
                </div>
                <div class="collage-item item-hor">
                    <img src="https://sevilla.abc.es/estilo/bulevarsur/wp-content/uploads/sites/14/2020/01/diez-claves-maquillaje-novia-impecable.jpg" alt="Maquillaje detalle">
                </div>
                <div class="collage-item item-small1">
                    <img src="https://images.unsplash.com/photo-1616683693504-3ea7e9ad6fec?ixlib=rb-1.2.1&auto=format&fit=crop&w=600&q=80" alt="Maquillaje evento">
                </div>
                <div class="collage-item item-small2">
                    <img src="https://expertosenestetica.es/wp-content/uploads/2022/03/MUA-TRENDS-2022-PH-Manuela-Zapata-MUA-Elisa-Gil-5.jpg" alt="Maquillaje editorial">
                </div>
            </div>
        </section>

        <section class="portfolio-lookbook">
            <div class="lookbook-textos">
                <h2>Historias Reales:</h2>
            </div>
            
            <div class="lookbook-grid">
                <article class="story-card">
                    <img src="https://images.unsplash.com/photo-1522337660859-02fbefca4702?q=80&w=800" alt="Boda Lucia">
                    <div class="story-card-content">
                        <div>
                            <p class="event-type">Boda en Finca</p>
                            <h3 class="story-title">Lucía & Carlos</h3>
                            <p class="story-excerpt">Ahumado suave en tonos tierra y piel radiante para una boda de tarde.</p>
                        </div>
                        <a href="#" class="story-btn">Ver Historia</a>
                    </div>
                </article>

                <article class="story-card">
                    <img src="https://images.unsplash.com/photo-1487412720507-e7ab37603c6f?q=80&w=800" alt="Editorial">
                    <div class="story-card-content">
                        <div>
                            <p class="event-type">Editorial de Moda</p>
                            <h3 class="story-title">Estilo Minimal</h3>
                            <p class="story-excerpt">Mirada gráfica, labios suaves y una composición elegante para sesión de revista.</p>
                        </div>
                        <a href="#" class="story-btn">Ver Historia</a>
                    </div>
                </article>

                <article class="story-card">
                    <img src="https://images.unsplash.com/photo-1546193430-c2d207739ed7?q=80&w=800" alt="Boda Carmen">
                    <div class="story-card-content">
                        <div>
                            <p class="event-type">Novia en Hotel</p>
                            <h3 class="story-title">Carmen & Pablo</h3>
                            <p class="story-excerpt">Piel perlada, rubor sutil y detalles de iluminación para un look nupcial atemporal.</p>
                        </div>
                        <a href="#" class="story-btn">Ver Historia</a>
                    </div>
                </article>
            </div>
        </section>
    </main>

    <div id="modal-historia" class="modal-historia" style="display: none;">
        <div class="modal-historia__overlay"></div>
        <div class="modal-historia__contenido">
            <button class="modal-historia__cerrar" type="button" aria-label="Cerrar modal">×</button>
            <div class="modal-historia__info">
                <p class="modal-historia__tag">Boda en Finca</p>
                <h2 class="modal-historia__titulo">Lucía & Carlos</h2>
                <p class="modal-historia__descripcion">Ahumado suave en tonos tierra, piel luminosa y una propuesta de maquillaje que acompaña cada instante del día nupcial con elegancia editorial.</p>
            </div>
            <div class="modal-historia__galeria">
                <div class="modal-historia__img"><img src="https://placehold.co/500x600/F8F1ED/333333?text=Foto+1" alt="Detalle maquillaje boda"></div>
                <div class="modal-historia__img"><img src="https://placehold.co/500x600/F8F1ED/333333?text=Foto+2" alt="Look de novia luminoso"></div>
                <div class="modal-historia__img"><img src="https://placehold.co/500x600/F8F1ED/333333?text=Foto+3" alt="Maquillaje de invitada elegante"></div>
            </div>
        </div>
    </div>

</BaseLayout>

<style>
    /* =========================================
       ESTILOS ENCAPSULADOS DEL PORTFOLIO
       ========================================= */
    .portfolio-main {
        position: relative;
        z-index: 1;
        background-color: var(--color-fondo);
        /* Franja rosa que usa tu variable corporativa */
        background: linear-gradient(to bottom, var(--color-suave) 0%, var(--color-suave) 380px, var(--color-fondo) 380px, var(--color-fondo) 100%);
        padding-top: 180px; 
        padding-bottom: 80px;
    }

    .portfolio-highlights { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
    .highlights-textos { text-align: center; max-width: 700px; margin: 0 auto 60px; }

    /* Tipografía 100% igual a la de Contacto y Servicios */
    .highlights-textos h1 { 
        font-family: var(--fuente-titulos); 
        font-size: 3.2rem; 
        font-weight: 500;
        color: var(--color-texto); 
        margin-bottom: 15px; 
    }

    .collage-grid { display: grid; grid-template-columns: repeat(4, 1fr); grid-auto-rows: 250px; gap: 20px; }
    .collage-item { overflow: hidden; border-radius: 4px; }
    .collage-item img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.3s ease-in-out; }
    .collage-item:hover img { transform: scale(1.05); }

    .item-big-v { grid-column: 1 / 3; grid-row: 1 / 3; }
    .item-hor   { grid-column: 3 / 5; grid-row: 1 / 2; }
    .item-small1{ grid-column: 3 / 4; grid-row: 2 / 3; }
    .item-small2{ grid-column: 4 / 5; grid-row: 2 / 3; }

    .portfolio-lookbook { max-width: 1200px; margin: 100px auto 0; padding: 0 20px; }
    .lookbook-textos h2 { font-family: var(--fuente-titulos); font-size: 2.5rem; color: var(--color-texto); text-align: center; margin-bottom: 50px; font-weight: 500;}
    .lookbook-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
    
    .story-card { background: #fff; border: 1px solid var(--color-suave); overflow: hidden; transition: box-shadow 0.3s ease; display: flex; flex-direction: column; border-radius: 4px;}
    .story-card:hover { box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
    .story-card img { width: 100%; height: 300px; object-fit: cover; }
    .story-card-content { padding: 25px; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
    
    .event-type { font-family: var(--fuente-textos); font-size: 0.8rem; text-transform: uppercase; color: var(--color-primario); letter-spacing: 2px; margin-bottom: 5px; font-weight: 600;}
    .story-title { font-family: var(--fuente-titulos); font-size: 1.6rem; color: var(--color-texto); margin-bottom: 15px; font-weight: 500;}
    .story-excerpt { font-family: var(--fuente-textos); font-size: 0.95rem; color: var(--color-secundario); line-height: 1.6; margin-bottom: 25px; }
    
    .story-btn { font-family: var(--fuente-textos); text-decoration: none; color: var(--color-texto); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 2px; border: 1px solid var(--color-texto); padding: 12px 25px; text-align: center; display: inline-block; transition: all 0.3s ease; align-self: center; font-weight: 600;}
    .story-btn:hover { background-color: var(--color-texto); color: var(--color-fondo); }

    /* =========================================
       RESPONSIVE MOBILE
       ========================================= */
    @media (max-width: 992px) {
        .collage-grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 200px; }
        .item-big-v { grid-column: 1 / 3; grid-row: 1 / 3; }
        .item-hor { grid-column: 1 / 3; grid-row: 3 / 4; }
        .item-small1, .item-small2 { grid-column: auto; grid-row: auto; }
        .lookbook-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
        .portfolio-main {
            /* Empujamos el texto hacia abajo y extendemos el rosa */
            background: linear-gradient(to bottom, var(--color-suave) 0%, var(--color-suave) 420px, var(--color-fondo) 420px, var(--color-fondo) 100%);
            padding-top: 240px; 
        }

        .highlights-textos {
            margin-top: 0;
            margin-bottom: 50px;
            padding-left: 20px;
            padding-right: 20px;
        }

        .highlights-textos h1 { font-size: 2.2rem; }

        .collage-grid { display: flex; flex-direction: column; gap: 15px; }
        .collage-item { height: 250px; }
        .lookbook-grid { grid-template-columns: 1fr; }
        .lookbook-textos h2 { font-size: 1.8rem; }
    }
</style>