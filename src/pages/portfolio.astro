---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import fotoColage1 from '../assets/img/portfolioColage1.webp';
import fotoColage2 from '../assets/img/portfolioColage2.webp';
import fotoColage3 from '../assets/img/portfolioColage3.jpg';
import fotoColage4 from '../assets/img/portfolioColage4.jpg';

// ==========================================
// 1. NUESTRA "BASE DE DATOS" DE HISTORIAS
// ==========================================
// Aquí es donde añadirás nuevas novias en el futuro. 
// Solo tienes que copiar un bloque de estos y cambiar los datos.
const historias = [
    {
        id: 'lorena', // Identificador único, sin espacios
        etiqueta: 'Boda de Día',
        titulo: 'Boda Lorena',
        descripcionCorta: 'Piel luminosa, mirada suave y un look nupcial diseñado para resistir lágrimas de felicidad.',
        descripcionLarga: 'Para el gran día de Lorena, buscábamos un acabado natural pero duradero. Preparamos la piel con mucha hidratación para conseguir ese efecto "glow" y centramos el protagonismo en una mirada suave con tonos tierra que resaltaba el color de sus ojos.',
        // Rutas de las imágenes (luego te explico dónde ponerlas)
        portada: '/img/portfolio/lorena/LorenaPortada.webp',
        cabecera: '/img/portfolio/lorena/LorenaCabecera.webp',
        fotos: [
            '/img/portfolio/lorena/LorenaBoda1.webp',
            '/img/portfolio/lorena/LorenaBoda2.webp',
            '/img/portfolio/lorena/LorenaBoda3.webp',
            '/img/portfolio/lorena/LorenaBoda4.webp',
            '/img/portfolio/lorena/LorenaBoda5.webp',
            '/img/portfolio/lorena/LorenaBoda6.webp',
            '/img/portfolio/lorena/LorenaBoda7.webp',
            '/img/portfolio/lorena/LorenaBoda8.webp'
            
        ]
    },
    // { ... aquí iría la siguiente historia cuando la tengas ... }
];
---

<BaseLayout title="Portfolio | Alba Sona MAKEUP">
    
    <main id="vista-principal" class="transicion-vista" style="display: block; opacity: 1;">
        <div class="portfolio-main">
            <section class="portfolio-highlights">
                <div class="highlights-textos">
                    <h1>Algunos de mis trabajos favoritos.</h1>
                </div>
                
                <div class="collage-grid">
                    <div class="collage-item item-big-v">
                        <Image src={fotoColage1} alt="Maquillaje novia principal" />
                    </div>
                    <div class="collage-item item-hor">
                        <Image src={fotoColage2} alt="Maquillaje detalle" />
                    </div>
                    <div class="collage-item item-small1">
                        <Image src={fotoColage3} alt="Maquillaje evento" class="fotoColage3"/>
                    </div>
                    <div class="collage-item item-small2">
                        <Image src={fotoColage4} alt="Maquillaje editorial"  class="fotoColage4"/>
                    </div>
                </div>
            </section>

            <section class="portfolio-lookbook">
                <div class="lookbook-textos">
                    <h2>Historias Reales:</h2>
                </div>
                
                <div class="lookbook-grid">
                    {/* Generamos las tarjetas dinámicamente leyendo nuestra "base de datos" */}
                    {historias.map((historia) => (
                        <article class="story-card">
                            <img src={historia.portada} alt={historia.titulo} loading="lazy" />
                            <div class="story-card-content">
                                <div>
                                    <p class="event-type">{historia.etiqueta}</p>
                                    <h3 class="story-title">{historia.titulo}</h3>
                                    <p class="story-excerpt">{historia.descripcionCorta}</p>
                                </div>
                                {/* Le ponemos un data-id al botón para que el JS sepa cuál abrir */}
                                <button class="story-btn btn-abrir-historia" data-id={historia.id}>Ver Historia</button>
                            </div>
                        </article>
                    ))}
                </div>
            </section>
        </div>
    </main>

    {/* Astro renderiza todas las galerías, pero las mantenemos ocultas */}
    {historias.map((historia) => (
        <section id={`galeria-${historia.id}`} class="vista-galeria transicion-vista" style="display: none; opacity: 0;">
            
            <div class="galeria-hero" style={`background-image: url('${historia.cabecera}')`}>
                <div class="galeria-hero-overlay"></div>
                <div class="galeria-hero-content">
                    <button class="btn-volver" aria-label="Volver atrás">
                        <span>←</span> Volver a Historias
                    </button>
                    <p class="galeria-tag">{historia.etiqueta}</p>
                    <h1 class="galeria-titulo-principal">{historia.titulo}</h1>
                </div>
            </div>

            <div class="galeria-cuerpo">
                <p class="galeria-texto-intro">{historia.descripcionLarga}</p>
                
                <div class="masonry-grid">
                    {historia.fotos.map((foto) => (
                        <div class="masonry-item">
                            <img src={foto} alt={`Foto de ${historia.titulo}`} loading="lazy" />
                        </div>
                    ))}
                </div>
            </div>
            
        </section>
    ))}

    <div id="visor-imagenes" class="visor-lightbox">
        <span class="visor-cerrar" aria-label="Cerrar imagen">&times;</span>
        <img id="visor-img" src="" alt="Imagen ampliada de maquillaje">
    </div>
    
</BaseLayout>

<style>
    /* =========================================
       ESTILOS GLOBALES DE TRANSICIÓN
       ========================================= */
    .transicion-vista {
        transition: opacity 0.4s ease-in-out; /* Esta es la magia del desvanecimiento */
    }

    /* =========================================
       VISTA 1: PORTFOLIO PRINCIPAL (Tus estilos originales intactos)
       ========================================= */
    .portfolio-main {
        position: relative;
        z-index: 1;
        background-color: var(--color-fondo);
        background: linear-gradient(to bottom, var(--color-suave) 0%, var(--color-suave) 380px, var(--color-fondo) 380px, var(--color-fondo) 100%);
        padding-top: 180px; 
        padding-bottom: 80px;
    }

    .portfolio-highlights { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
    .highlights-textos { text-align: center; max-width: 700px; margin: 0 auto 60px; }
    .highlights-textos h1 { 
        font-family: var(--fuente-titulos); 
        font-size: 3.2rem; 
        font-weight: 500;
        color: var(--color-texto); 
        margin-bottom: 15px; 
    }

    .collage-grid { display: grid; grid-template-columns: repeat(4, 1fr); grid-auto-rows: 250px; gap: 20px; }
    .collage-item { overflow: hidden; border-radius: 4px; }
    .collage-item img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.3s ease-in-out; }
    .collage-item:hover img { transform: scale(1.05); }

    .item-big-v { grid-column: 1 / 3; grid-row: 1 / 3; }
    .item-hor   { grid-column: 3 / 5; grid-row: 1 / 2; }
    .item-small1{ grid-column: 3 / 4; grid-row: 2 / 3; }
    .item-small2{ grid-column: 4 / 5; grid-row: 2 / 3; }

    .portfolio-lookbook { max-width: 1200px; margin: 100px auto 0; padding: 0 20px; }
    .lookbook-textos h2 { font-family: var(--fuente-titulos); font-size: 2.5rem; color: var(--color-texto); text-align: center; margin-bottom: 50px; font-weight: 500;}
    .lookbook-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
    
    .story-card { background: #fff; border: 1px solid var(--color-suave); overflow: hidden; transition: box-shadow 0.3s ease; display: flex; flex-direction: column; border-radius: 4px;}
    .story-card:hover { box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
    .story-card img { width: 100%; height: 300px; object-fit: cover; }
    .story-card-content { padding: 25px; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
    
    .event-type { font-family: var(--fuente-textos); font-size: 0.8rem; text-transform: uppercase; color: var(--color-primario); letter-spacing: 2px; margin-bottom: 5px; font-weight: 600;}
    .story-title { font-family: var(--fuente-titulos); font-size: 1.6rem; color: var(--color-texto); margin-bottom: 15px; font-weight: 500;}
    .story-excerpt { font-family: var(--fuente-textos); font-size: 0.95rem; color: var(--color-secundario); line-height: 1.6; margin-bottom: 25px; }
    
    /* Cuidado: Hemos cambiado la etiqueta <a> por un <button> para manejar el JS */
    .story-btn { background: transparent; cursor: pointer; font-family: var(--fuente-textos); text-decoration: none; color: var(--color-texto); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 2px; border: 1px solid var(--color-texto); padding: 12px 25px; text-align: center; display: inline-block; transition: all 0.3s ease; align-self: center; font-weight: 600;}
    .story-btn:hover { background-color: var(--color-texto); color: var(--color-fondo); }

    /* =========================================
       VISTA 2: ESTILOS DE LA GALERÍA (Nuevo)
       ========================================= */
    .vista-galeria {
        background-color: var(--color-fondo);
        min-height: 100vh;
        padding-bottom: 100px;
    }

    .galeria-hero {
        position: relative;
        width: 100%;
        height: 70vh; /* Ocupa el 70% de la pantalla */
        background-size: cover;
        background-position: center center; /* Enfoca la parte de arriba de la foto */
        display: flex;
        align-items: flex-end; /* Texto abajo */
    }

    .galeria-hero-overlay {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.6) 100%);
    }

    .galeria-hero-content {
        position: relative;
        z-index: 2;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    .btn-volver {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.5);
        color: #fff;
        padding: 10px 20px;
        border-radius: 50px;
        cursor: pointer;
        font-family: var(--fuente-textos);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 30px;
        transition: background 0.3s ease;
    }
    .btn-volver:hover { background: rgba(255,255,255,0.2); }

    .galeria-tag {
        color: var(--color-primario);
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .galeria-titulo-principal {
        font-family: var(--fuente-titulos);
        font-size: 4rem;
        color: #fff;
        font-weight: 500;
        text-shadow: 2px 2px 10px rgba(0,0,0,0.3);
    }

    .galeria-cuerpo {
        max-width: 1200px;
        margin: 0 auto;
        padding: 60px 20px 0;
    }

    .galeria-texto-intro {
        font-family: var(--fuente-textos);
        font-size: 1.1rem;
        color: var(--color-secundario);
        line-height: 1.8;
        max-width: 800px;
        margin: 0 auto 60px auto;
        text-align: center;
    }

    /* El famoso estilo Masonry (Grid tipo Pinterest) */
    .masonry-grid {
        column-count: 3; /* 3 columnas en escritorio */
        column-gap: 20px;
    }

    .masonry-item {
        break-inside: avoid; /* Evita que una foto se corte por la mitad al cambiar de columna */
        margin-bottom: 20px;
    }

    .masonry-item img {
        width: 100%;
        display: block;
        border-radius: 4px;
    }

    /* =========================================
       ESTILOS DEL LIGHTBOX (Zoom de imágenes)
       ========================================= */
    
    /* 1. Indicador visual en las fotos de la galería */
    .masonry-item img {
        cursor: zoom-in;
        transition: filter 0.3s ease;
    }
    
    .masonry-item img:hover {
        filter: brightness(0.85); /* Oscurece un pelín para invitar al clic */
    }

    /* 2. El fondo de pantalla completa (oculto por defecto) */
    .visor-lightbox {
        position: fixed;
        z-index: 9999; /* Por encima de todo */
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.92); /* Negro casi opaco elegante */
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        pointer-events: none; /* Evita clics invisibles */
        transition: opacity 0.3s ease; /* Desvanecimiento suave */
    }

    /* 3. Clase que añadiremos con JS para mostrarlo */
    .visor-lightbox.activo {
        opacity: 1;
        pointer-events: auto;
    }

    /* 4. La imagen ampliada */
    .visor-lightbox img {
        max-width: 90%;
        max-height: 90vh; /* Que no se salga del alto de la pantalla */
        object-fit: contain;
        border-radius: 4px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.5);
        transform: scale(0.95); /* Empieza un poco más pequeña */
        transition: transform 0.3s ease;
    }

    .visor-lightbox.activo img {
        transform: scale(1); /* Crece suavemente al aparecer */
    }

    /* 5. El botón de cerrar (la X) */
    .visor-cerrar {
        position: absolute;
        top: 30px;
        right: 40px;
        color: #f1f1f1;
        font-size: 45px;
        font-weight: 300;
        cursor: pointer;
        transition: color 0.3s ease;
    }

    .visor-cerrar:hover {
        color: var(--color-primario); /* Toque corporativo al pasar el ratón */
    }

    /* =========================================
       RESPONSIVE MOBILE
       ========================================= */
    @media (max-width: 992px) {
        .collage-grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 200px; }
        .item-big-v { grid-column: 1 / 3; grid-row: 1 / 3; }
        .item-hor { grid-column: 1 / 3; grid-row: 3 / 4; }
        .item-small1, .item-small2 { grid-column: auto; grid-row: auto; }
        .lookbook-grid { grid-template-columns: repeat(2, 1fr); }
        .masonry-grid { column-count: 2; } /* 2 columnas en tablet */
    }

    @media (max-width: 768px) {
        .portfolio-main {
            background: linear-gradient(to bottom, var(--color-suave) 0%, var(--color-suave) 420px, var(--color-fondo) 420px, var(--color-fondo) 100%);
            padding-top: 240px; 
        }
        .highlights-textos { margin-top: 0; margin-bottom: 50px; padding-left: 20px; padding-right: 20px; }
        .highlights-textos h1 { font-size: 2.2rem; }
        .collage-grid { display: flex; flex-direction: column; gap: 15px;}
        .collage-item { height: 250px; }
        .lookbook-grid { grid-template-columns: 1fr; }
        .lookbook-textos h2 { font-size: 1.8rem; }
        
        /* Ajustes galería móvil */
        .galeria-hero { height: 60vh; }
        .galeria-titulo-principal { font-size: 2.5rem; }
        .masonry-grid { column-count: 1; } /* 1 columna en móvil */


        .fotoColage3 {object-position: center 30%;}
        .fotoColage4 {object-position: center 30%;}

    }

</style>

<script>
    // Usamos un evento que espera a que Astro haya cargado la página
    document.addEventListener('astro:page-load', () => {
        
        // 1. Añadimos "as HTMLElement" para tranquilizar a TypeScript
        const vistaPrincipal = document.getElementById('vista-principal') as HTMLElement;
        const botonesAbrir = document.querySelectorAll('.btn-abrir-historia');
        const botonesVolver = document.querySelectorAll('.btn-volver');

        // ==========================================
        // Lógica para ABRIR una galería
        // ==========================================
        botonesAbrir.forEach(boton => {
            boton.addEventListener('click', () => {
                const idHistoria = boton.getAttribute('data-id');
                const galeriaObjetivo = document.getElementById(`galeria-${idHistoria}`) as HTMLElement;

                // Comprobamos que existen antes de hacer nada
                if (galeriaObjetivo && vistaPrincipal) {
                    vistaPrincipal.style.opacity = '0';
                    setTimeout(() => {
                        vistaPrincipal.style.display = 'none';
                        galeriaObjetivo.style.display = 'block';
                        window.scrollTo(0, 0);
                        setTimeout(() => {
                            galeriaObjetivo.style.opacity = '1';
                        }, 50); 
                    }, 400); 
                }
            });
        });

        // ==========================================
        // Lógica para VOLVER a la rejilla principal
        // ==========================================
        botonesVolver.forEach(boton => {
            boton.addEventListener('click', () => {
                const galeriaActiva = boton.closest('.vista-galeria') as HTMLElement;
                
                if (galeriaActiva && vistaPrincipal) {
                    galeriaActiva.style.opacity = '0';

                    setTimeout(() => {
                        galeriaActiva.style.display = 'none';
                        vistaPrincipal.style.display = 'block';
                        
                        const seccionHistorias = document.querySelector('.portfolio-lookbook') as HTMLElement;
                        if(seccionHistorias) {
                            const offsetTop = seccionHistorias.getBoundingClientRect().top + window.scrollY - 100;
                            window.scrollTo({ top: offsetTop, behavior: 'instant' }); 
                        }

                        setTimeout(() => {
                            vistaPrincipal.style.opacity = '1';
                        }, 50);
                    }, 400);
                }
            });
        });

        // ==========================================
        // LÓGICA DEL LIGHTBOX (Zoom de imágenes)
        // ==========================================
        const visor = document.getElementById('visor-imagenes') as HTMLElement;
        const visorImg = document.getElementById('visor-img') as HTMLImageElement;
        const btnCerrarVisor = document.querySelector('.visor-cerrar') as HTMLElement;
        
        // Le decimos específicamente que esto es una lista de imágenes
        const imagenesGaleria = document.querySelectorAll('.masonry-item img') as NodeListOf<HTMLImageElement>;

        // A. Abrir el visor
        if (imagenesGaleria) {
            imagenesGaleria.forEach(img => {
                img.addEventListener('click', () => {
                    if (visorImg && visor) {
                        visorImg.src = img.src; 
                        visor.classList.add('activo'); 
                    }
                });
            });
        }

        // B. Función maestra para cerrar
        const cerrarVisor = () => {
            if (visor) visor.classList.remove('activo');
        };

        // C. Cerrar al hacer clic en la "X"
        if(btnCerrarVisor) {
            btnCerrarVisor.addEventListener('click', cerrarVisor);
        }

        // D. Cerrar al hacer clic en el fondo negro
        if(visor) {
            visor.addEventListener('click', (e) => {
                if (e.target === visor) cerrarVisor();
            });
        }

        // E. Cerrar con la tecla "Escape"
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && visor && visor.classList.contains('activo')) {
                cerrarVisor();
            }
        });

    }); 
</script>