---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';

// Importamos los iconos para que Astro los optimice automáticamente
import iconInstaPink from '../assets/img/icon-instagram-pink.png';
import iconInstaColor from '../assets/img/icon-instagram-color.png';
import iconFbPink from '../assets/img/icon-facebook-pink.png';
import iconFbColor from '../assets/img/icon-facebook-color.png';
import iconWaPink from '../assets/img/icon-whatsapp-pink.png';
import iconWaColor from '../assets/img/icon-whatsapp-color.png';
---

<BaseLayout title="Contacto | Alba Sona MAKEUP | Maquillaje Profesional">
    
    <main class="contacto-main">
        <section class="hero-contacto">
            <div class="hero-contenido">
                <h1>Ponte en contacto conmigo</h1>
                <p>¿Tienes una boda, evento especial o proyecto en mente? Me encantaría ayudarte a crear el maquillaje perfecto para tu día.</p>
            </div>
        </section>

        <section class="contacto-contenedor" id="contacto">
            <div class="contacto-grid-principal">
                
                <div class="contacto-info">
                    <h2>Mi Información de Contacto</h2>
                    
                    <div class="info-item">
                        <h3>Ubicación</h3>
                        <p>Calle Belleza, 42<br>
                        28001 Madrid, España<br>
                        Estudio privado exclusivo</p>
                    </div>

                    <div class="info-item">
                        <h3>Teléfono</h3>
                        <p>+34 612 345 678</p>
                    </div>

                    <div class="info-item">
                        <h3>Email</h3>
                        <p>info@albasonamakeup.com</p>
                    </div>

                    
                </div>

                <div class="contacto-metodos">
                    <h2>Sígueme y Contáctame</h2>
                    
                    <div class="contacto-grid-tarjetas">
                        <div class="contacto-card">
                            <div class="icono-wrapper">
                                <Image src={iconInstaPink} alt="Instagram" class="icon-default" />
                                <Image src={iconInstaColor} alt="Instagram" class="icon-hover" />
                            </div>
                            <h3>Instagram</h3>
                            <p>@albasonamakeup</p>
                            <a href="https://www.instagram.com/albasonamakeup" target="_blank" class="btn-principal">Seguir</a>
                        </div>

                        <div class="contacto-card">
                            <div class="icono-wrapper">
                                <Image src={iconFbPink} alt="Facebook" class="icon-default" />
                                <Image src={iconFbColor} alt="Facebook" class="icon-hover" />
                            </div>
                            <h3>Facebook</h3>
                            <p>Alba Sona Makeup</p>
                            <a href="https://www.facebook.com/albasonamakeup" target="_blank" class="btn-principal">Seguir</a>
                        </div>

                        <div class="contacto-card">
                            <div class="icono-wrapper">
                                <Image src={iconWaPink} alt="WhatsApp" class="icon-default" />
                                <Image src={iconWaColor} alt="WhatsApp" class="icon-hover" />
                            </div>
                            <h3>WhatsApp</h3>
                            <p>+34 612 345 678</p>
                            <a href="https://wa.me/34612345678" target="_blank" class="btn-principal">Escribir</a>
                        </div>
                    </div>

                    <div class="nota-contacto">
                        <p>✨ Respondo todos los mensajes en un máximo de 24 horas. Para citas urgentes, prefiero contactar por WhatsApp.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="cta-cierre">
            <h2>¿Listo para tu transformación?</h2>
            <p>Envíame un mensaje con los detalles de tu evento o proyecto</p>
            <a href="https://wa.me/34612345678" class="btn-principal">Contactar por WhatsApp</a>
        </section>
    </main>

</BaseLayout>

<style>
    /* =========================================
       ESTILOS ENCAPSULADOS DEL CONTACTO
       ========================================= */
    .contacto-main {
        background-color: var(--color-fondo);
    }

    .hero-contacto { 
        background-color: var(--color-suave); 
        padding: 180px 5% 80px; 
        text-align: center; 
        margin-top: 0; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
    }
    
    .hero-contenido { max-width: 700px; width: 100%; margin: 0 auto; }
    
    .hero-contenido h1 { 
        font-family: var(--fuente-titulos); 
        font-size: 3.2rem; 
        font-weight: 500; 
        color: var(--color-texto); 
        margin-bottom: 20px; 
    }
    
    .hero-contenido p { 
        font-family: var(--fuente-textos);
        font-size: 1.2rem; 
        color: var(--color-secundario); 
        max-width: 600px; 
        margin: 0 auto; 
    }

    .contacto-contenedor { max-width: 1400px; margin: 80px auto; padding: 0 5%; }
    
    /* Nota: He cambiado los nombres de las clases grid para evitar conflictos de anidamiento */
    .contacto-grid-principal { display: grid; grid-template-columns: minmax(320px, 1fr) 2fr; gap: 60px; padding: 50px 0; align-items: start; }
    .contacto-grid-tarjetas { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; padding: 50px 0; }
    
    .contacto-card { border: 1px solid var(--color-suave); background-color: var(--color-fondo); padding: 40px; text-align: center; border-radius: 8px; transition: box-shadow 0.3s ease; display: flex; flex-direction: column; justify-content: space-between; }
    .contacto-card:hover { box-shadow: 0 10px 30px rgba(224, 162, 162, 0.1); }
    
    .icono-wrapper { position: relative; display: flex; justify-content: center; align-items: center; width: 60px; height: 60px; margin: 0 auto 20px auto; }
    .icono-wrapper img { position: absolute; width: 100%; height: 100%; object-fit: contain; transition: opacity 0.3s ease; }
    .icon-default { opacity: 1; }
    .icon-hover { opacity: 0; }
    .contacto-card:hover .icon-default { opacity: 0; }
    .contacto-card:hover .icon-hover { opacity: 1; }
    
    .contacto-card h3 { font-family: var(--fuente-titulos); font-size: 2rem; font-weight: 500; margin-bottom: 10px; color: var(--color-texto); }
    .contacto-card p { font-family: var(--fuente-textos); font-size: 1.1rem; color: var(--color-secundario); margin-bottom: 20px; }
    
    .contacto-card .btn-principal { background-color: var(--color-primario); color: #fff; border: none; border-radius: 30px; padding: 10px 25px; text-decoration: none; font-size: 1rem; font-weight: 600; box-shadow: 0 8px 18px rgba(224, 162, 162, 0.35); transition: background-color 0.3s ease;}
    .contacto-card .btn-principal:hover { background-color: var(--color-secundario); }
    
    .contacto-info h2 { font-size: 1.8rem; font-family: var(--fuente-textos); font-weight: 600; letter-spacing: 0.5px; color: var(--color-texto); margin-bottom: 30px; line-height: 1.3; text-align: center; }
    .contacto-metodos h2 { font-family: var(--fuente-titulos); font-size: 2.2rem; font-weight: 500; color: var(--color-texto); margin-bottom: 40px; text-align: center; }
    
    .info-item { margin-bottom: 25px; padding-bottom: 25px; border-bottom: 1px solid var(--color-suave); }
    .info-item:last-child { border-bottom: none; }
    .info-item h3 { font-size: 0.9rem; font-family: var(--fuente-textos); font-weight: 700; color: var(--color-texto); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; }
    .info-item p { font-family: var(--fuente-textos); color: var(--color-texto); font-size: 1rem; line-height: 1.8; }
    
    .nota-contacto { background-color: var(--color-suave); padding: 25px; border-radius: 10px; text-align: center; }
    .nota-contacto p { font-family: var(--fuente-textos); color: var(--color-texto); font-size: 0.95rem; margin: 0; line-height: 1.6;}
    
    .cta-cierre { background: linear-gradient(135deg, var(--color-secundario) 0%, #4a3644 100%); padding: 80px 5%; text-align: center; margin: 80px 0 0 0; }
    .cta-cierre h2 { font-family: var(--fuente-titulos); font-size: 2.5rem; font-weight: 500; color: white; margin-bottom: 15px; }
    .cta-cierre p { font-family: var(--fuente-textos); font-size: 1.1rem; color: rgba(255, 255, 255, 0.9); margin-bottom: 35px; }
    .cta-cierre .btn-principal { background-color: var(--color-primario); color: var(--color-texto); padding: 15px 40px; border-radius: 30px; text-decoration: none; display: inline-block; font-weight: 600; transition: all 0.3s ease; border: 2px solid var(--color-primario); }
    .cta-cierre .btn-principal:hover { background-color: transparent; color: var(--color-primario); }

    /* =========================================
       RESPONSIVE MOBILE
       ========================================= */
    @media (max-width: 768px) {
        .hero-contacto {
            padding-top: 240px; 
            padding-bottom: 50px;
        }

        .hero-contenido h1 {
            font-size: 2.2rem;
        }

        .contacto-grid-principal,
        .contacto-grid-tarjetas {
            display: grid;
            grid-template-columns: 1fr; /* Forzamos a que sea 1 sola columna */
            gap: 40px;
        }

        .contacto-card {
            width: 100%;
            box-sizing: border-box;
        }
    }
</style>